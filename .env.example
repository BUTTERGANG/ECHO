# ECHO environment variables. Copy to `.env` (gitignored).

# ─── SERVER (production web on Replit) ───────────────────────────────────────
# Set these as Replit Deployment Secrets — they live ONLY on the server and
# never reach the client bundle.
ANTHROPIC_API_KEY=
# Optional server tuning:
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ALLOWED_ORIGIN=https://your-deployment.replit.app
# COEP_POLICY=require-corp

# ─── NATIVE DEV ONLY ─────────────────────────────────────────────────────────
# Used by the native (iOS/Android) dev build to call Anthropic directly.
# DO NOT set this for the web build — EXPO_PUBLIC_* values are inlined into the
# bundle and would leak the key. Web uses the server proxy instead.
# EXPO_PUBLIC_ANTHROPIC_API_KEY=
